# Mode de scraping
SCRAPER_MODE=stealth           # stealth | fast | debug
HEADLESS=true                  # false pour debug visuel

# Délais (en secondes)
DELAY_BETWEEN_REQUESTS_MIN=3
DELAY_BETWEEN_REQUESTS_MAX=8
DELAY_BETWEEN_PAGES_MIN=5
DELAY_BETWEEN_PAGES_MAX=12

# Limites
MAX_PROFILES=100
MAX_RETRIES=3

# Proxy (optionnel)
PROXY_URL=
